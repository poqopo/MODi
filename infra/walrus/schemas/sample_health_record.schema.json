{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modi.local/schemas/sample_health_record.schema.json",
  "title": "MODi MVP Sample Health Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ageRange",
    "gender",
    "regionCode",
    "conditionTags",
    "glucoseRange",
    "deviceType",
    "recordedMonth"
  ],
  "properties": {
    "ageRange": {
      "type": "string",
      "enum": ["20-29", "30-39", "40-49", "50-59", "60-69"]
    },
    "gender": {
      "type": "string",
      "enum": ["female", "male", "non_disclosed"]
    },
    "regionCode": {
      "type": "string",
      "enum": ["KR-SEOUL", "KR-GYEONGGI", "KR-BUSAN", "KR-OTHER"]
    },
    "conditionTags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["diabetes", "hypertension", "obesity", "sleep", "activity"]
      }
    },
    "glucoseRange": {
      "type": "string",
      "enum": ["normal", "100-125", "126-139", "140-179", "180-plus"]
    },
    "deviceType": {
      "type": "string",
      "enum": ["wearable", "manual_entry", "lab_summary"]
    },
    "recordedMonth": {
      "type": "string",
      "pattern": "^20[0-9]{2}-(0[1-9]|1[0-2])$"
    }
  }
}

