{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modi.local/schemas/data_request.schema.json",
  "title": "MODi MVP Data Request Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "purpose",
    "requiredAgeRanges",
    "requiredConditionTags",
    "allowedUse",
    "retentionDays"
  ],
  "properties": {
    "purpose": {
      "type": "string",
      "enum": ["diabetes_research", "hypertension_research", "wearable_behavior_research"]
    },
    "requiredAgeRanges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["20-29", "30-39", "40-49", "50-59", "60-69"]
      }
    },
    "requiredConditionTags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["diabetes", "hypertension", "obesity", "sleep", "activity"]
      }
    },
    "allowedUse": {
      "type": "string",
      "enum": ["aggregate_analysis", "model_training", "research_report"]
    },
    "retentionDays": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365
    }
  }
}
